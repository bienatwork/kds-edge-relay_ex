# Copy to `.env` on the Pi and fill in real values (.env is gitignored).
#   cp .env.pi.example .env

# Database + broker passwords (used by both the infra containers and the API connection strings).
POSTGRES_PASSWORD=change-me-postgres
RABBITMQ_PASSWORD=change-me-rabbitmq

# Relay JWT signing key — must be at least 32 bytes. Generate one, e.g.:
#   openssl rand -base64 48
JWT_SIGNING_KEY=change-me-32-bytes-minimum

# Upstream legacy live-API service account (see spec §0 open items).
UPSTREAM_BASE_URL=https://api.olouris.co.uk/api/v1
UPSTREAM_EMAIL=service@example.co.uk
UPSTREAM_PASSWORD=change-me-upstream

# Image the compose file pulls/runs. For the GHCR flow use the registry path;
# for the offline tarball flow use the local tag (kds-relay:latest).
RELAY_IMAGE=ghcr.io/bienatwork/kds-relay:latest
